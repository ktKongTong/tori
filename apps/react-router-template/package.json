{
  "name": "react-router-template",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "dev:bun": "RUNTIME=bun bun --bun react-router dev",
    "dev:deno": "RUNTIME=deno deno run --unstable-cron -A vite dev",
    "dev:node": "RUNTIME=node react-router dev",
    "dev:worker": "RUNTIME=workerd react-router dev",
    "build": "RUNTIME=node react-router build",
    "build:worker": "RUNTIME=workerd react-router build",
    "build:bun": "RUNTIME=bun react-router build",
    "build:deno": "RUNTIME=deno react-router build",
    "start": "node ./build/server/index.js",
    "start:deno": "deno run --unstable-cron -A ./build/server/index.js",
    "deploy:worker": "wrangler deploy",
    "typecheck": "react-router typegen && tsgo"
  },
  "dependencies": {
    "@hono/node-server": "catalog:hono",
    "@phosphor-icons/react": "catalog:icons",
    "@react-router/node": "catalog:react-router",
    "@react-router/serve": "catalog:react-router",
    "@remixicon/react": "catalog:icons",
    "@repo/ui": "workspace:*",
    "hono": "catalog:hono",
    "isbot": "^5.1.31",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "react-router": "catalog:react-router"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "catalog:worker",
    "@cloudflare/workers-types": "catalog:worker",
    "@react-router/dev": "catalog:react-router",
    "@rolldown/plugin-babel": "catalog:",
    "@tailwindcss/vite": "catalog:tailwindcss",
    "@types/bun": "catalog:",
    "@types/deno": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@vitejs/plugin-react": "catalog:",
    "babel-plugin-react-compiler": "catalog:",
    "react-router-hono-server": "catalog:",
    "tailwindcss": "catalog:tailwindcss",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "wrangler": "catalog:worker"
  }
}
