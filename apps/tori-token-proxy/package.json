{
  "name": "token-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "dev:worker": "RUNTIME=workerd vp dev",
    "dev:deno": "RUNTIME=deno deno run --unstable-cron -A vite dev",
    "dev:bun": "RUNTIME=bun bun --bun run vp dev",
    "build": "vp build",
    "build:bun": "RUNTIME=bun vp build",
    "build:deno": "RUNTIME=deno vp build",
    "build:worker": "RUNTIME=workerd vp build",
    "preview": "vp preview",
    "s": "deno -A .output/server/index.mjs",
    "preview:bun": "RUNTIME=bun bun --bun run vp preview",
    "preview:deno": "RUNTIME=deno deno run --unstable-cron -A vite preview",
    "preview:worker": "RUNTIME=workerd vp preview",
    "test": "vp test",
    "test:watch": "vp test --watch",
    "db:gen": "vp exec drizzle-kit generate",
    "db:gen:pg": "vp exec drizzle-kit generate --config drizzle.config.ts",
    "db:gen:sqlite": "vp exec drizzle-kit generate --config drizzle.config.sqlite.ts",
    "db:migrate": "vp exec drizzle-kit migrate",
    "db:migrate:pg": "vp exec drizzle-kit migrate --config drizzle.config.ts",
    "db:migrate:sqlite": "vp exec drizzle-kit migrate --config drizzle.config.sqlite.ts",
    "db:up": "vp exec drizzle-kit up",
    "db:up:pg": "vp exec drizzle-kit up --config drizzle.config.ts",
    "db:up:sqlite": "vp exec drizzle-kit up --config drizzle.config.sqlite.ts",
    "deploy:worker": "vp run build:worker && wrangler deploy",
    "cf-typegen": "wrangler types",
    "typecheck": "wrangler types && tsgo --noEmit",
    "deploy:deno": "deno deploy"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@repo/data-table": "workspace:*",
    "@repo/ui": "workspace:*",
    "@repo/utils": "workspace:*",
    "@tabler/icons-react": "catalog:icons",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-router": "catalog:tanstack-start",
    "@tanstack/react-start": "catalog:tanstack-start",
    "@tanstack/react-table": "catalog:",
    "@tanstack/router-plugin": "catalog:tanstack-start",
    "drizzle-orm": "catalog:drizzle",
    "hono": "catalog:hono",
    "nitro": "catalog:",
    "ofetch": "2.0.0-alpha.3",
    "pg": "^8.20.0",
    "qrcode.react": "^4.2.0",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "steam-session": "^1.9.4",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "catalog:worker",
    "@cloudflare/workers-types": "catalog:worker",
    "@rolldown/plugin-babel": "catalog:",
    "@tailwindcss/vite": "catalog:tailwindcss",
    "@types/bun": "catalog:",
    "@types/deno": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@vitejs/plugin-react": "catalog:",
    "babel-plugin-react-compiler": "catalog:",
    "drizzle-kit": "catalog:drizzle",
    "tailwindcss": "catalog:tailwindcss",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "wrangler": "catalog:worker"
  }
}
