{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "moduleDetection": "force",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "strict": true,
    "noUnusedLocals": true,
    "declaration": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "paths": {
      "@repo/core/errors/*": ["../core/src/errors/*.ts"],
      "@repo/core/utils/*": ["../core/src/utils/*.ts"],
      "@repo/core/*": ["../core/src/*"]
    }
  },
  "include": ["src", "tests", "vite.config.ts"]
}
