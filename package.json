{
  "name": "fullstack-edge-template",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "type": "module",
  "scripts": {
    "on:ready": "vp check && vp run -r test && vp run -r build",
    "ins": "npx pnpm@10.33.2 install",
    "build:proxy:node": "vp run -v -t token-proxy#build",
    "build:proxy:deno": "RUNTIME=deno vp run -v -t token-proxy#build",
    "migrate:proxy": "vp run -v --filter=token-proxy db:migrate:pg",
    "dev": "vp run website#dev",
    "prepare": "vp config",
    "check": "vp check .",
    "check:write": "vp check --fix .",
    "lint:write": "vp lint --fix .",
    "b": "vp run build"
  },
  "dependencies": {
    "srvx": "^0.11.16"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/deno": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@10.33.2"
}
